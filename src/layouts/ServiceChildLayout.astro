---
import BaseLayout from './BaseLayout.astro';
import { site } from '../data/siteData.js';
const { parent, child, siblingServices, title, description, canonicalPath } = Astro.props;
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="hero compact">
    <img src="/images/hero.png" alt={child.name} />
    <div class="hero-copy"><p class="eyebrow">{parent.name}</p><h1>{child.name} in Frederick, MD</h1><p>{child.summary}</p><a href="/contact/" class="btn">Request Service</a></div>
  </section>
  <section class="section split">
    <article class="article"><h2>{child.name}: what Frederick property owners should know</h2>{child.content.map((p) => <p>{p}</p>)}</article>
    <aside class="panel"><h3>Signals this service fits</h3>{child.symptoms.map((item) => <p>{item}</p>)}<h3>Expected benefits</h3>{child.benefits.map((item) => <p>{item}</p>)}</aside>
  </section>
  <section class="section"><h2>Our process</h2><div class="steps">{child.process.map((step, i) => <div><span>{i + 1}</span><p>{step}</p></div>)}</div></section>
  <section class="section muted"><h2>Questions about {child.name.toLowerCase()}</h2>{child.faqs.map((faq) => <details><summary>{faq.question}</summary><p>{faq.answer}</p></details>)}</section>
  <section class="section"><h2>Related {parent.name.toLowerCase()} services</h2><div class="cards small">{siblingServices.slice(0, 4).map((sibling) => <a class="card" href={`/services/${parent.slug}/${sibling.slug}/`}><h3>{sibling.name}</h3><p>{sibling.summary}</p></a>)}</div></section>
</BaseLayout>