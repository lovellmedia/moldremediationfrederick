---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, serviceFamilies } from '../data/siteData.js';
---
<BaseLayout title={site.title + ' | Frederick, MD'} description={site.sub} canonicalPath="/">
  <section class="hero">
    <img src="/images/hero.png" alt={site.hero} />
    <div class="hero-copy">
      <p class="eyebrow">Frederick, Maryland</p>
      <h1>{site.hero}</h1>
      <p>{site.sub}</p>
      <div class="hero-actions">
        <a href="/contact/" class="btn">Request A Local Estimate</a>
        <a href="/services/" class="btn ghost">Explore Services</a>
      </div>
    </div>
  </section>
  <section class="proof">{site.proof.map((item) => <div><span></span>{item}</div>)}</section>
  <section class="section conversion-intro">
    <div class="intro-copy">
      <p class="eyebrow dark">Problem-Focused Planning</p>
      <h2>{site.homeLead}</h2>
      <p class="lede">{site.homePain}</p>
      <p>{site.homePromise}</p>
      <ul class="check-list">{site.homeBullets.map((item) => <li>{item}</li>)}</ul>
    </div>
    <aside class="estimate-card">
      <h3>Get A Clear Next Step Today</h3>
      <ul>
        <li>Tell us what is happening at your property</li>
        <li>Share timing, urgency, and access details</li>
        <li>Get a practical scope with priorities</li>
        <li>Choose the option that fits your goals</li>
      </ul>
      <a href="/contact/" class="btn">Request Service</a>
    </aside>
  </section>
  <section class="section">
    <h2>Choose The Service You Need</h2>
    <div class="cards">{serviceFamilies.map((family) => <a class="card" href={`/services/${family.slug}/`}><h3>{family.name}</h3><p>{family.shortDescription}</p></a>)}</div>
  </section>
  <section class="conversion-strip">
    <div>
      <p class="eyebrow">Frederick Service Team</p>
      <h2>{site.homeClose}</h2>
      <p>Call now or request service online and get a straightforward plan built around your property.</p>
    </div>
    <a href="/contact/" class="btn light">Request Service</a>
  </section>
  <section class="section split">
    <div>
      <h2>Why Property Owners Choose {site.business}</h2>
      <p>You get direct answers, clear scope, and work that is built around local conditions in Frederick.</p>
      <p>We keep communication simple, planning practical, and execution clean so you can move forward with confidence.</p>
    </div>
    <aside class="panel sidebar-list">
      <h3>What You Should Expect</h3>
      <ul>
        <li>Plain-English recommendations</li>
        <li>Transparent scope and priorities</li>
        <li>Respectful, organized service crews</li>
        <li>A result reviewed before closeout</li>
      </ul>
      <h3>Service Area</h3>
      <ul>{site.serviceArea.map((area) => <li>{area}</li>)}</ul>
    </aside>
  </section>
</BaseLayout>